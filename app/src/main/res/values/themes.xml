<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Trucogold" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/light_primary</item>
        <item name="colorSecondary">@color/light_secondary</item>
        <item name="android:windowBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_nav_bar</item>
        <item name="navSelectedIconColor">@color/white</item>
        <item name="navSelectedBgColor">@color/light_primary</item>
    </style>

    <style name="Theme.Trucogold" parent="Base.Theme.Trucogold" />

    <style name="Theme.Trucogold.SplashScreen" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Trucogold</item>
    </style>
</resources>